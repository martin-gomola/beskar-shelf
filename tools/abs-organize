#!/usr/bin/env bash
set -euo pipefail

# Reorganize audiobook downloads into Audiobookshelf-compatible Author/Title structure.
# Fixes common grab output issues: wrong author folders, redundant metadata in titles.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
DOWNLOADS="${1:-$REPO_ROOT/downloads}"
DRY_RUN=false

if [[ "${1:-}" == "--dry-run" ]]; then
    DRY_RUN=true
    DOWNLOADS="${2:-$REPO_ROOT/downloads}"
elif [[ "${2:-}" == "--dry-run" ]]; then
    DRY_RUN=true
fi

if [ ! -d "$DOWNLOADS" ]; then
    echo "Downloads directory not found: $DOWNLOADS"
    exit 1
fi

moves=()

plan_move() {
    local src="$1"
    local dst="$2"

    if [ "$src" = "$dst" ]; then
        return
    fi
    if [ ! -d "$src" ]; then
        return
    fi
    moves+=("$src|$dst")
}

strip_trailing() {
    echo "$1" | sed -E 's/[[:space:]]*$//' | sed -E 's/[[:space:]]*-[[:space:]]*$//'
}

# --- Define reorganization rules ---

D="$DOWNLOADS"

# Mluvené Slovo → Jules Verne (publisher used as author; extract real author from title)
if [ -d "$D/Mluvené Slovo" ]; then
    for book_dir in "$D/Mluvené Slovo"/*/; do
        [ -d "$book_dir" ] || continue
        basename="$(basename "$book_dir")"

        # Strip "Jules Verne" prefix and clean title
        title="$basename"
        title="${title#Jules Verne }"
        title="${title#Jules Verne-}"
        title="${title#Jules Verne - }"
        # Remove trailing SK/CZ language tags
        title=$(echo "$title" | sed -E 's/[[:space:]]+(SK|CZ)[[:space:]]*$//')
        # Clean leading/trailing whitespace
        title=$(echo "$title" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

        plan_move "$D/Mluvené Slovo/$basename" "$D/Jules Verne/$title"
    done
fi

# Zaklínač → Andrzej Sapkowski (series name used as author; extract story title)
if [ -d "$D/Zaklínač" ]; then
    for book_dir in "$D/Zaklínač"/*/; do
        [ -d "$book_dir" ] || continue
        basename="$(basename "$book_dir")"

        # These are short stories from "Poslední přání" (The Last Wish).
        # Extract the actual story name from patterns like:
        #   "Poslední praní - Mensi zlo - Poviedka - Kniha I"
        #   "poslední přání - Poslední přání - Poviedka - kniha - I"
        #   "Poslední prání - Hlas rozumu - Zaklínač - poviedka - kniha I"
        title="$basename"

        # Remove known metadata suffixes (case-insensitive)
        title=$(echo "$title" | sed -E 's/[[:space:]]*-[[:space:]]*(P|p)oviedka[^-]*//g')
        title=$(echo "$title" | sed -E 's/[[:space:]]*-[[:space:]]*(K|k)niha[[:space:]]*-?[[:space:]]*(I|II|III|IV|V|VI|VII|1|2|3|4|5|6|7)[[:space:]]*$//g')
        title=$(echo "$title" | sed -E 's/[[:space:]]*-[[:space:]]*(Z|z)aklínač[[:space:]]*//g')

        # For two-part titles like "Poslední přání - Menší zlo", take the second part
        # (the first is the book name, the second is the story name)
        if echo "$title" | grep -qE '^[Pp]oslední (přání|praní|prání) - '; then
            title=$(echo "$title" | sed -E 's/^[Pp]oslední (přání|praní|prání) - //')
        fi

        title=$(echo "$title" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        title=$(strip_trailing "$title")

        plan_move "$D/Zaklínač/$basename" "$D/Andrzej Sapkowski/$title"
    done
fi

# Emhyr var Emreis → Andrzej Sapkowski (character name used as author)
if [ -d "$D/Emhyr var Emreis" ]; then
    for book_dir in "$D/Emhyr var Emreis"/*/; do
        [ -d "$book_dir" ] || continue
        basename="$(basename "$book_dir")"

        title="$basename"
        # Remove " - poviedka - Gerald z Rivie" and similar suffixes
        title=$(echo "$title" | sed -E 's/[[:space:]]*-[[:space:]]*(P|p)oviedka[^-]*//g')
        title=$(echo "$title" | sed -E 's/[[:space:]]*-[[:space:]]*(G|g)erald z Rivi[ei][[:space:]]*$//g')
        title=$(echo "$title" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        title=$(strip_trailing "$title")

        plan_move "$D/Emhyr var Emreis/$basename" "$D/Andrzej Sapkowski/$title"
    done
fi

# Andrzej Sapkowski — already correct author, clean titles
if [ -d "$D/Andrzej Sapkowski" ]; then
    for book_dir in "$D/Andrzej Sapkowski"/*/; do
        [ -d "$book_dir" ] || continue
        basename="$(basename "$book_dir")"

        title="$basename"
        # Remove "Zaklínač- " or "Zaklínač - " prefix (series name in title)
        title=$(echo "$title" | sed -E 's/^Zaklínač[[:space:]]*-[[:space:]]*//')
        # Remove trailing language tags like "(CZ)"
        title=$(echo "$title" | sed -E 's/[[:space:]]*\((CZ|SK|EN)\)[[:space:]]*$//')
        title=$(echo "$title" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

        if [ "$title" != "$basename" ]; then
            plan_move "$D/Andrzej Sapkowski/$basename" "$D/Andrzej Sapkowski/$title"
        fi
    done
fi

# Jules Verne — already correct author, clean titles if needed
if [ -d "$D/Jules Verne" ]; then
    for book_dir in "$D/Jules Verne"/*/; do
        [ -d "$book_dir" ] || continue
        basename="$(basename "$book_dir")"

        title="$basename"
        title=$(echo "$title" | sed -E 's/[[:space:]]*\((CZ|SK|EN)\)[[:space:]]*$//')
        title=$(echo "$title" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

        if [ "$title" != "$basename" ]; then
            plan_move "$D/Jules Verne/$basename" "$D/Jules Verne/$title"
        fi
    done
fi

# --- Print plan ---

if [ ${#moves[@]} -eq 0 ]; then
    echo "Nothing to reorganize. All folders already match ABS structure."
    exit 0
fi

echo "Planned moves (${#moves[@]}):"
echo ""
for entry in "${moves[@]}"; do
    src="${entry%%|*}"
    dst="${entry##*|}"
    rel_src="${src#"$DOWNLOADS"/}"
    rel_dst="${dst#"$DOWNLOADS"/}"
    echo "  $rel_src"
    echo "    → $rel_dst"
    echo ""
done

if $DRY_RUN; then
    echo "Dry run — no files moved."
    exit 0
fi

# --- Execute moves ---

echo "Executing..."
for entry in "${moves[@]}"; do
    src="${entry%%|*}"
    dst="${entry##*|}"
    dst_parent="$(dirname "$dst")"

    mkdir -p "$dst_parent"

    if [ -d "$dst" ]; then
        # Merge into existing destination
        for f in "$src"/*; do
            [ -e "$f" ] || continue
            mv "$f" "$dst/"
        done
        rmdir "$src" 2>/dev/null || true
    else
        mv "$src" "$dst"
    fi

    rel_src="${src#"$DOWNLOADS"/}"
    rel_dst="${dst#"$DOWNLOADS"/}"
    echo "  ✓ $rel_src → $rel_dst"
done

# --- Remove empty author directories ---

for dir in "$DOWNLOADS"/*/; do
    [ -d "$dir" ] || continue
    if [ -z "$(find "$dir" -mindepth 1 -maxdepth 1 -not -name '.DS_Store' -print -quit 2>/dev/null)" ]; then
        rmdir "$dir" 2>/dev/null || rm -rf "$dir" 2>/dev/null || true
        echo "  ✓ Removed empty: $(basename "$dir")/"
    fi
done

echo ""
echo "Done. Rescan the library in Audiobookshelf to pick up the changes."
