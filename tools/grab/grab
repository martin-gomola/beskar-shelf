#!/usr/bin/env bash
# Thin shim: delegates to the beskar_tools.cli.grab Python module.
# The real logic lives under tools/beskar_tools/.

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
TOOLS_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

exec env BESKAR_SHIM_CALLER="$SCRIPT_PATH" "$TOOLS_DIR/_shim.sh" beskar_tools.cli.grab "$@"
