#!/usr/bin/env python3
"""
Export and apply missing Audiobookshelf descriptions.

Usage examples:
  ./tools/fill-abs-descriptions --list-missing
  ./tools/fill-abs-descriptions --export-missing descriptions.todo.json
  ./tools/fill-abs-descriptions --apply descriptions.todo.json
"""

from __future__ import annotations

import argparse
import json
import os
import sys
import urllib.error
import urllib.request
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parent.parent
ENV_FILE = REPO_ROOT / ".env"


def load_env() -> dict[str, str]:
    env: dict[str, str] = {}
    if not ENV_FILE.exists():
      return env

    for raw_line in ENV_FILE.read_text().splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        env[key] = value.strip().strip('"')
    return env


def request_json(base_url: str, token: str, path: str, *, method: str = "GET", payload: dict | None = None):
    headers = {
        "Authorization": f"Bearer {token}",
        "Accept": "application/json",
        "User-Agent": "Mozilla/5.0",
    }
    data = None
    if payload is not None:
        headers["Content-Type"] = "application/json"
        data = json.dumps(payload, ensure_ascii=False).encode("utf-8")

    request = urllib.request.Request(
        f"{base_url.rstrip('/')}{path}",
        headers=headers,
        method=method,
        data=data,
    )
    with urllib.request.urlopen(request, timeout=60) as response:
        body = response.read().decode("utf-8")
        return json.loads(body) if body else None


def fetch_library_items(base_url: str, token: str, library_id: str) -> list[dict]:
    response = request_json(
        base_url,
        token,
        f"/api/libraries/{library_id}/items?limit=2000&minified=0&collapseseries=0&sort=media.metadata.title&desc=0",
    )
    return response.get("results", response)


def find_missing_descriptions(items: list[dict]) -> list[dict]:
    results: list[dict] = []
    for item in items:
        media = item.get("media") or {}
        metadata = media.get("metadata") or {}
        description = (metadata.get("description") or "").strip()
        if description:
            continue
        results.append(
            {
                "id": item["id"],
                "title": metadata.get("title") or "",
                "author": metadata.get("authorName") or metadata.get("author") or "",
                "series": metadata.get("seriesName") or "",
                "publishedYear": metadata.get("publishedYear") or "",
                "description": "",
            }
        )
    return results


def apply_descriptions(base_url: str, token: str, entries: list[dict]) -> tuple[int, list[str]]:
    updated = 0
    errors: list[str] = []
    for entry in entries:
        description = (entry.get("description") or "").strip()
        item_id = entry.get("id")
        if not item_id or not description:
            continue
        try:
            request_json(
                base_url,
                token,
                f"/api/items/{item_id}/media",
                method="PATCH",
                payload={"metadata": {"description": description}},
            )
            updated += 1
        except urllib.error.HTTPError as exc:
            body = exc.read().decode("utf-8", "ignore")
            errors.append(f"{item_id}: HTTP {exc.code} {body}".strip())
        except Exception as exc:  # noqa: BLE001
            errors.append(f"{item_id}: {exc}")
    return updated, errors


def main() -> int:
    parser = argparse.ArgumentParser(description="Export and apply missing ABS descriptions.")
    parser.add_argument("--list-missing", action="store_true", help="Print books with missing descriptions.")
    parser.add_argument("--export-missing", metavar="PATH", help="Write missing-description entries to a JSON file.")
    parser.add_argument("--apply", metavar="PATH", help="Apply descriptions from a JSON file.")
    args = parser.parse_args()

    if not args.list_missing and not args.export_missing and not args.apply:
        parser.error("Choose one or more actions: --list-missing, --export-missing, --apply")

    env = load_env()
    base_url = env.get("ABS_LOCAL_URL") or env.get("ABS_URL")
    token = env.get("ABS_TOKEN")
    library_id = env.get("ABS_LIBRARY_ID")

    if not base_url or not token or not library_id:
        print("ABS_URL or ABS_LOCAL_URL, ABS_TOKEN, and ABS_LIBRARY_ID are required in .env.", file=sys.stderr)
        return 1

    try:
        items = fetch_library_items(base_url, token, library_id)
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", "ignore")
        print(f"Failed to read library items: HTTP {exc.code} {body}", file=sys.stderr)
        return 1

    missing = find_missing_descriptions(items)

    if args.list_missing:
        for entry in missing:
            print(f'{entry["id"]}\t{entry["author"]}\t{entry["title"]}')
        print(f"\nMissing descriptions: {len(missing)}")

    if args.export_missing:
        output_path = Path(args.export_missing)
        output_path.write_text(json.dumps(missing, ensure_ascii=False, indent=2) + "\n")
        print(f"Exported {len(missing)} entries to {output_path}")

    if args.apply:
        source_path = Path(args.apply)
        entries = json.loads(source_path.read_text())
        updated, errors = apply_descriptions(base_url, token, entries)
        print(f"Updated descriptions: {updated}")
        if errors:
            print("\nErrors:", file=sys.stderr)
            for error in errors:
                print(f"- {error}", file=sys.stderr)
            return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
