OUTPUT_DIR="./downloads"

# Split files longer than this (seconds, default: 3600 = 1 hour)
# SPLIT_THRESHOLD=3600

# Fixed split segment length (seconds, default: 1800 = 30 min)
# SEGMENT_LENGTH=1800

# Audiobookshelf API (for metadata management)
# ABS_URL="https://your-audiobookshelf-instance/audiobookshelf"
# ABS_TOKEN="your-api-token"
# ABS_LIBRARY_ID="your-library-id"
