# Beskar Shelf app settings (Vite-prefixed vars are exposed to the browser)
VITE_APP_NAME=Beskar Shelf
VITE_DEFAULT_SERVER_URL=
VITE_ABS_PROXY_BASE=/abs

# Optional Audiobookshelf API values for local tooling and dev proxying
# ABS_URL="https://your-audiobookshelf-instance"
# ABS_TOKEN="your-api-token"
# ABS_LIBRARY_ID="your-library-id"

# Docker Compose deployment settings
IMAGE_NAME=beskar-shelf
CONTAINER_NAME=beskar-shelf-pwa
APP_PORT=4173
ABS_UPSTREAM=https://books.example.com
